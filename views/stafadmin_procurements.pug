doctype html
html
  head
    title= title
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css")
  body.bg-light
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      div.container
        a.navbar-brand(href="/") Sistem Manajemen Laboratorium
        div.d-flex.align-items-center
          span.text-light.me-3 Halo, #{user.name} (#{user.role})
          a.btn.btn-outline-danger.btn-sm(href="/logout") Logout

    div.container.mt-5
      div.d-flex.justify-content-between.align-items-center.mb-4
        h2.fw-bold Draf Pengadaan Disetujui
        div.d-flex.gap-2
          input#searchInput.form-control(type="text" placeholder="Cari draf..." style="max-width: 250px;")
          a.btn.btn-secondary(href="/") Kembali ke Dashboard

      if error
        div.alert.alert-danger.alert-dismissible.fade.show(role="alert")
          | #{error}
          button.btn-close(type="button", data-bs-dismiss="alert", aria-label="Close")
      if success
        div.alert.alert-success.alert-dismissible.fade.show(role="alert")
          | #{success}
          button.btn-close(type="button", data-bs-dismiss="alert", aria-label="Close")

      div.card.shadow
        div.card-body
          if procurementsList.length > 0
            div.table-responsive
              table.table.table-hover.align-middle
                thead.table-light
                  tr
                    th ID
                    th Tahun
                    th Judul Pengadaan
                    th Dibuat Oleh
                    th Tanggal Dibuat
                    th Status
                    th Aksi
                tbody
                  each proc in procurementsList
                    tr
                      td= proc.id
                      td= proc.year
                      td= proc.title
                      td= proc.creator_name
                      td= new Date(proc.created_at).toLocaleDateString('id-ID')
                      td
                        div.d-flex.flex-column.align-items-start.gap-1
                          span.badge.bg-success Final
                          if proc.total_approved > 0
                            if proc.total_received == 0
                              span.badge.bg-danger Belum Diterima
                            else if proc.total_received < proc.total_approved
                              span.badge.bg-warning.text-dark Diterima Sebagian (#{proc.total_received}/#{proc.total_approved})
                            else
                              span.badge.bg-info Diterima Semua (#{proc.total_approved})
                      td
                        a.btn.btn-primary.btn-sm(href=`/stafadmin/procurements/${proc.id}`) Detail & Terima Barang
          else
            div.alert.alert-info Tidak ada draf pengadaan yang sudah difinalisasi.

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script.
      const searchInput = document.getElementById('searchInput');
      if(searchInput) {
        searchInput.addEventListener('keyup', function() {
          let filter = this.value.toLowerCase();
          let rows = document.querySelectorAll('tbody tr');
          rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            row.style.display = text.includes(filter) ? '' : 'none';
          });
        });
      }
