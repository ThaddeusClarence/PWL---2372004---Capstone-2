doctype html
html
  head
    title= title
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body.bg-light
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      div.container
        a.navbar-brand(href="#")= title
        div.d-flex.align-items-center
          span.text-light.me-3 Halo, #{user.name} (#{user.role})
          a.btn.btn-outline-danger.btn-sm(href="/logout") Logout
    div.container.mt-5
      div.row.justify-content-center
        div.col-md-8
          div.card.shadow.p-5.text-center
            h1.text-primary.fw-bold= message
            p.lead.text-secondary Sistem digitalisasi aset laboratorium dan BHP
            hr
            
            //- Tampilkan menu sesuai role (Contoh sederhana)
            if user.role === 'Administrator'
              div.d-grid.gap-2.d-md-block
                button.btn.btn-success.me-2(type="button") Kelola Ruangan
                button.btn.btn-outline-primary(type="button") Kelola Pengguna
            else if user.role === 'Kepala Laboratorium'
              div.d-grid.gap-2.d-md-block
                button.btn.btn-success.me-2(type="button") Buat Draf Pengadaan
                button.btn.btn-outline-secondary(type="button") Lihat Draf
            else if user.role === 'Ketua Program Studi'
              div.d-grid.gap-2.d-md-block
                button.btn.btn-primary.me-2(type="button") Review Draf Pengadaan
            else if user.role === 'Staf Administrasi'
              div.d-grid.gap-2.d-md-block
                button.btn.btn-info.me-2(type="button") Update Inventaris (QR/Barcode)
                button.btn.btn-warning(type="button") Input Penerimaan Barang
            else if user.role === 'Staf Laboratorium'
              div.d-grid.gap-2.d-md-block
                button.btn.btn-primary.me-2(type="button") Kelola Stok BHP
                button.btn.btn-warning(type="button") Log Maintenance & Update Kondisi