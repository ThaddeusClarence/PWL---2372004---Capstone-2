doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Login - Sistem Inventaris Laboratorium
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css")
    link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap")
    style.
      body {
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #0f172a, #1e293b, #334155);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .login-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: none;
        border-radius: 20px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        overflow: hidden;
        width: 100%;
        max-width: 420px;
      }
      .login-header {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        padding: 30px 20px;
        text-align: center;
        color: white;
      }
      .login-icon {
        font-size: 48px;
        margin-bottom: 10px;
        color: #ffffff;
      }
      .form-control, .form-select {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        padding: 12px 16px;
        border-radius: 10px;
        color: #0f172a;
      }
      .form-control:focus, .form-select:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        background-color: #ffffff;
      }
      .form-label {
        font-size: 14px;
        font-weight: 500;
        color: #475569;
        margin-bottom: 8px;
      }
      .btn-login {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        border: none;
        border-radius: 10px;
        padding: 12px;
        font-weight: 600;
        font-size: 16px;
        color: white;
        width: 100%;
        transition: all 0.3s ease;
      }
      .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.3);
      }
      .error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        border-radius: 10px;
        padding: 12px 16px;
        font-size: 14px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .input-group-text {
        background-color: #f8fafc;
        border-color: #e2e8f0;
        color: #64748b;
      }

  body
    .container.px-4
      .row.justify-content-center
        .col-12.d-flex.justify-content-center
          .login-card
            .login-header
              i.bi.bi-shield-lock-fill.login-icon
              h3.fw-bold.mb-1 Sistem Inventaris
              p.mb-0.text-white-50 Laboratorium Terpadu
            
            .card-body.p-4
              if error
                .error-alert
                  i.bi.bi-exclamation-triangle-fill
                  span= error
                  
              form(action="/login" method="POST")
                .mb-3
                  label.form-label(for="role") Login Sebagai
                  .input-group
                    span.input-group-text
                      i.bi.bi-person-badge
                    select.form-select(id="role" name="role" required)
                      option(value="" disabled selected) -- Pilih Peran Anda --
                      option(value="Administrator") Administrator
                      option(value="Kepala Laboratorium") Kepala Laboratorium
                      option(value="Ketua Program Studi") Ketua Program Studi
                      option(value="Staf Administrasi") Staf Administrasi
                      option(value="Staf Laboratorium") Staf Laboratorium
                
                .mb-3
                  label.form-label(for="email") Email
                  .input-group
                    span.input-group-text
                      i.bi.bi-envelope
                    input.form-control(type="email" id="email" name="email" placeholder="Masukkan alamat email" required autocomplete="off")
                
                .mb-4
                  label.form-label(for="password") Password
                  .input-group
                    span.input-group-text
                      i.bi.bi-key
                    input.form-control(type="password" id="password" name="password" placeholder="Masukkan password" required)
                
                button.btn-login(type="submit")
                  i.bi.bi-box-arrow-in-right.me-2
                  | Masuk ke Sistem
