doctype html
html
  head
    title= title
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css")
  body.bg-light
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      div.container
        a.navbar-brand(href="/") Sistem Manajemen Laboratorium
        div.d-flex.align-items-center
          span.text-light.me-3 Halo, #{user.name} (#{user.role})
          a.btn.btn-outline-danger.btn-sm(href="/logout") Logout

    div.container.mt-5
      div.d-flex.justify-content-between.align-items-center.mb-4
        h2.fw-bold Detail Penerimaan Barang
        a.btn.btn-secondary(href="/stafadmin/procurements") Kembali

      if error
        div.alert.alert-danger.alert-dismissible.fade.show(role="alert")
          | #{error}
          button.btn-close(type="button", data-bs-dismiss="alert", aria-label="Close")
      if success
        div.alert.alert-success.alert-dismissible.fade.show(role="alert")
          | #{success}
          button.btn-close(type="button", data-bs-dismiss="alert", aria-label="Close")

      div.card.shadow.mb-4
        div.card-body
          h4.card-title #{procurement.title} (#{procurement.year})
          p.card-text
            strong Status Draf: 
            span.badge.bg-success Final
          p.card-text
            strong Dibuat Oleh: 
            span #{procurement.creator_name} pada #{new Date(procurement.created_at).toLocaleDateString('id-ID')}

      h4.mb-3 Daftar Item Disetujui (Siap Diterima)

      div.card.shadow
        div.card-body
          if items.length > 0
            div.table-responsive
              table.table.table-hover.align-middle
                thead.table-light
                  tr
                    th Tipe
                    th Nama Barang
                    th Qty
                    th Pengganti Untuk
                    th Tanggal Terima
                    th Aksi Penerimaan
                tbody
                  each item in items
                    tr
                      td
                        if item.item_type === 'Inventory'
                          span.badge.bg-primary Aset/Inventaris
                        else
                          span.badge.bg-info BHP/Consumable
                      td= item.name
                      td= item.quantity
                      td
                        if item.replace_inventory_id
                          span.badge.bg-secondary #{item.replace_item_name}
                        else
                          span.text-muted -
                      td
                        if item.received_date
                          span.text-success #{new Date(item.received_date).toLocaleDateString('id-ID')}
                        else
                          span.text-warning Belum Diterima
                      td
                        if !item.received_date
                          button.btn.btn-primary.btn-sm(type="button", data-bs-toggle="modal", data-bs-target=`#receiveModal${item.id}`)
                            i.bi.bi-box-arrow-in-down.me-1
                            | Terima Barang
                        else
                          span.badge.bg-success Selesai

            // Modals for Receiving Items
            each item in items
              if !item.received_date
                div.modal.fade(id=`receiveModal${item.id}`, tabindex="-1", aria-labelledby=`receiveModalLabel${item.id}`, aria-hidden="true")
                  div.modal-dialog
                    div.modal-content
                      div.modal-header
                        h5.modal-title(id=`receiveModalLabel${item.id}`) Terima Barang: #{item.name}
                        button.btn-close(type="button", data-bs-dismiss="modal", aria-label="Close")
                      form(action=`/stafadmin/procurements/${procurement.id}/item/${item.id}/receive`, method="POST", enctype="multipart/form-data")
                        div.modal-body
                          div.mb-3
                            label.form-label(for=`received_date_${item.id}`) Tanggal Diterima
                            input.form-control(type="date", id=`received_date_${item.id}`, name="received_date", required)
                          
                          if item.item_type === 'Inventory'
                            div.mb-3
                              label.form-label(for=`item_code_${item.id}`) Nomor Label/Kode Inventaris
                              input.form-control(type="text", id=`item_code_${item.id}`, name="item_code", required, placeholder="Misal: INV-2026-001")
                            
                            div.mb-3
                              label.form-label(for=`room_id_${item.id}`) Lokasi Ruangan
                              select.form-select(id=`room_id_${item.id}`, name="room_id", required)
                                option(value="") Pilih Ruangan...
                                each room in rooms
                                  option(value=room.id)= room.name

                            div.mb-3
                              label.form-label(for=`qr_code_${item.id}`) Upload Foto QR Code / Barcode (Opsional)
                              input.form-control(type="file", id=`qr_code_${item.id}`, name="qr_code", accept="image/*")
                          else
                            div.alert.alert-info Barang tipe BHP akan otomatis ditambahkan ke stok.

                        div.modal-footer
                          button.btn.btn-secondary(type="button", data-bs-dismiss="modal") Batal
                          button.btn.btn-primary(type="submit") Simpan Data Penerimaan
          else
            div.alert.alert-info Tidak ada item yang disetujui pada draf pengadaan ini.

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
